# Makefile
CXX = g++
CXXFLAGS = -Wall -Wextra -std=c++11
TARGET = sport_db
OBJ = sport.o main.o

all: $(TARGET)

$(TARGET): $(OBJ)
	$(CXX) $(CXXFLAGS) -o $@ $^

sport.o: sport.cpp sport2.h
	$(CXX) $(CXXFLAGS) -c sport.cpp -o sport.o

main.o: main.cpp sport2.h
	$(CXX) $(CXXFLAGS) -c main.cpp -o main.o

clean:
	rm -f $(OBJ) $(TARGET) sport.dat

run: $(TARGET)
	./$(TARGET)

rebuild: clean all

.PHONY: all clean run rebuild
